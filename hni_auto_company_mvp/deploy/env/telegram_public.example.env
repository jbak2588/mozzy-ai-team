# Copy this file outside git tracking before real deployment.
# Example target path:
# /etc/hni_auto_company/telegram_public.env

# Local backend listen port.
HNI_BACKEND_PORT=8787

# Optional orchestration timing.
HNI_STAGE_DELAY_MS=300

# Optional persistent state path for the backend service user.
HNI_BACKEND_STATE_FILE=/var/lib/hni_auto_company/backend_state.json

# Required Telegram bot token from BotFather.
HNI_TELEGRAM_BOT_TOKEN=replace-with-bot-token

# Optional override. Keep default unless you need a custom Bot API gateway.
HNI_TELEGRAM_API_BASE_URL=https://api.telegram.org

# Public HTTPS base URL reachable by Telegram.
HNI_TELEGRAM_WEBHOOK_BASE_URL=https://ai.humantric.net

# Shared secret expected by the backend webhook route.
HNI_TELEGRAM_WEBHOOK_SECRET=replace-with-random-webhook-secret

# Allowlist at least one command source.
# Use numeric identifiers from Telegram updates in production.
HNI_TELEGRAM_ALLOWED_CHAT_IDS=replace-with-chat-id
HNI_TELEGRAM_ALLOWED_SENDER_IDS=replace-with-sender-id
HNI_TELEGRAM_ALLOWED_USERNAMES=replace-with-telegram-username

# Approver allowlist for approval commands.
HNI_TELEGRAM_APPROVER_SENDER_IDS=replace-with-approver-sender-id
HNI_TELEGRAM_APPROVER_USERNAMES=replace-with-approver-username

# Public webhook profile must disable polling.
HNI_TELEGRAM_POLLING_ENABLED=false

# Polling envs are left blank on purpose in webhook mode.
# Do not enable polling and webhook at the same time.
